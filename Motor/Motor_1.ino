/*
 * =========================================================
 * 电机控制教学示例（Motor Control Teaching Demo）
 * =========================================================
 *
 * 本示例用于演示 ESP32C3 如何通过 Motor.hpp
 * 实现直流电机的：
 *   1. 正转
 *   2. 反转
 *   3. 停止
 *
 * 非常适合作为：
 *   - 电机驱动板硬件测试
 *   - 初学者电机控制入门
 *   - PID平衡杆项目的基础
 *
 * ---------------------------------------------------------
 * 淘宝店铺：极点电子
 * 哔哩哔哩：无处在很无聊
 *
 * 创建时间：2026-01-14
 * ---------------------------------------------------------
 *
 * 使用说明：
 *   motor.run( 正数PWM )  → 电机正转
 *   motor.run( 负数PWM )  → 电机反转
 *   motor.flameout()      → 电机停止
 *
 * =========================================================
 */

// #include <Arduino.h>   // Arduino 核心库（VS Code编译需要）
#include "Motor.hpp"   // 电机控制封装库

// =========================================================
// 一、创建电机对象
// =========================================================
// Motor( IN1, IN2, PWM_A, PWM_B )
//
// IN1 / IN2 ：方向控制引脚
// PWM_A/B  ：PWM 输出引脚（由 Motor.hpp 内部使用）
//
// ⚠️ 引脚号需与你的硬件接线完全一致
// =========================================================
Motor motor(
  7,   // IN1：电机方向控制引脚 1
  10,  // IN2：电机方向控制引脚 2
  0,   // PWM A：PWM 输出引脚
  1    // PWM B：PWM 输出引脚
);

// =========================================================
// 二、电机转速参数
// =========================================================
// PWM 范围：0 ~ 255
// 数值越大，转速越快
// 建议第一次测试不要超过 150
// =========================================================
int pwmValue = 120;

// =========================================================
// 三、初始化函数（只执行一次）
// =========================================================
void setup() {

  // 初始化串口，用于调试观察
  Serial.begin(115200);

  // 给串口一点启动时间
  delay(1000);

  Serial.println("=== Motor Control Teaching Demo Start ===");

  // -------------------------------------------------------
  // 非常重要！
  // 上电第一时间让电机停止
  // 防止 IO 上电瞬间为高电平导致电机误转
  // -------------------------------------------------------
  motor.flameout();
}

// =========================================================
// 四、主循环函数（反复执行）
// =========================================================
void loop() {

  // -------------------------------------------------------
  // 1️⃣ 电机正转
  // -------------------------------------------------------
  // motor.run(正数) 表示电机正方向旋转
  // 正负方向由你的接线方式决定
  // -------------------------------------------------------
  Serial.println("Motor Forward");
  motor.run(pwmValue);
  delay(2000);   // 保持 2 秒

  // -------------------------------------------------------
  // 2️⃣ 电机停止
  // -------------------------------------------------------
  // flameout() 会关闭 PWM 并停止电机
  // -------------------------------------------------------
  Serial.println("Motor Stop");
  motor.flameout();
  delay(1000);   // 停 1 秒

  // -------------------------------------------------------
  // 3️⃣ 电机反转
  // -------------------------------------------------------
  // motor.run(负数) 表示反方向旋转
  // -------------------------------------------------------
  Serial.println("Motor Reverse");
  motor.run(-pwmValue);
  delay(2000);   // 保持 2 秒

  // -------------------------------------------------------
  // 4️⃣ 再次停止
  // -------------------------------------------------------
  Serial.println("Motor Stop");
  motor.flameout();
  delay(1000);
}
